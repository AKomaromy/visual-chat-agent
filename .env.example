# ClickHouse Cloud — create a service at https://clickhouse.cloud (redeem the
# hackathon's $400 credit first, from an email that has NOT used a ClickHouse
# trial before). Use the HTTPS interface URL, e.g. https://<host>:8443
CLICKHOUSE_URL=
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Trigger.dev — create a project at https://cloud.trigger.dev (redeem the
# hackathon's $5 credit first, from an email that has NOT used a Trigger.dev
# trial before). The project ref (proj_xxx) also needs to replace the
# placeholder in trigger.config.ts — it is not a secret, but the CLI reads it
# from that file, not from an env var.
TRIGGER_SECRET_KEY=

# Added when Task 5 (real getBriefing tool) and profile-card extraction are
# implemented — not required for Task 1.
# OPENAI_API_KEY=
